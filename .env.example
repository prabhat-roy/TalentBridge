# ============================================================
# Project-wide local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (primary transactional store) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# ----- MongoDB -----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=app

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Kafka -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- NATS JetStream -----
NATS_URL=nats://localhost:4222

# ----- Object storage (MinIO) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=app

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/app
OIDC_CLIENT_ID=app
OIDC_CLIENT_SECRET=change-me

# ----- Vault -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686